# Database — set one of the following formats:
# Supabase (current): postgresql+psycopg2://postgres:[password]@db.[ref].supabase.co:5432/postgres
# MySQL (production):  mysql+pymysql://[user]:[password]@[host]:3306/[dbname]
DATABASE_URL=

# AI APIs (server-side only — NEVER expose to frontend)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Auth
AUTH_SERVICE_URL=
SESSION_SECRET=change-this-to-random-64-char-string
CSRF_SECRET=change-this-to-another-random-64-char-string
SESSION_EXPIRY_HOURS=24

# App
ENVIRONMENT=dev
DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]

# File upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=/var/data/whitehelmet/uploads
