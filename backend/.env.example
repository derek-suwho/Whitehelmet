# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=whitehelmet
DB_USER=whitehelmet
DB_PASSWORD=changeme

# AI APIs (server-side only — NEVER expose to frontend)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Auth
AUTH_SERVICE_URL=
SESSION_SECRET=change-this-to-random-64-char-string
CSRF_SECRET=change-this-to-another-random-64-char-string
SESSION_EXPIRY_HOURS=24

# App
ENVIRONMENT=dev
DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]

# File upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=/var/data/whitehelmet/uploads
