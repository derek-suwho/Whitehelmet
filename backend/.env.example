# Database — set one of the following formats:


DATABASE_URL=mysql+pymysql://whitehelmet:changeme@db:3306/whitehelmet

# AI APIs (server-side only — NEVER expose to frontend)
ANTHROPIC_API_KEY=                       # optional if using OpenRouter
OPENROUTER_API_KEY=

# Auth
AUTH_MODE=local                         # "local" | "keycloak"
SESSION_SECRET=change-this-to-random-64-char-string
CSRF_SECRET=change-this-to-another-random-64-char-string
SESSION_EXPIRY_HOURS=24

# Keycloak / SSO (required when AUTH_MODE=keycloak)
KEYCLOAK_URL=                           # e.g. https://auth.client.com  [PENDING]
KEYCLOAK_REALM=                         # e.g. pif  [PENDING]
KEYCLOAK_CLIENT_ID=whitehelmet
KEYCLOAK_LOGIN_URL=                     # CS Dashboard login URL  [PENDING]
AUTH_SERVICE_URL=                       # Laravel auth service base URL  [PENDING]

# OCI MySQL (dev instance)
# DATABASE_URL=mysql+pymysql://user:pass@10.32.10.184:3306/whitehelmet
DB_SSL_CA=                              # Path to CA cert, e.g. /etc/ssl/mysql-ca.pem

# App
ENVIRONMENT=dev
DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]

# File upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=/var/data/whitehelmet/uploads
